class Solution:
    def romanToInt(self, s: str) -> int:
        roman_nums = {
        "I" : 1,
        "V" : 5,
        "X" : 10,
        "L" : 50,
        "C" : 100,
        "D" : 500,
        "M" : 1000
        }

        value_as_int = 0

        for i in range(len(s)):
            if i + 1 < len(s) and roman_nums[s[i]] < roman_nums[s[i+1]]:
                value_as_int -= roman_nums[s[i]]
            else:
                value_as_int += roman_nums[s[i]]

        return value_as_int
